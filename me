<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Simran — Graphic Designer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,600;1,9..144,500&display=swap" rel="stylesheet">
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://unpkg.com/lucide@latest"></script>
<style>
  :root{
    --ink:#17140F;
    --paper:#F6F1E6;
    --paper-line:#E4DAC2;
    --rose:#E23A5D;
    --tape:#F2C14E;
    --muted:#867F70;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'Geist', sans-serif; background-color:var(--paper); -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale; }
  .font-display { font-family:'Fraunces', serif; }

  @keyframes fadeSlideUp { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
  .fade-up-1 { animation: fadeSlideUp 0.8s ease 0.2s both; }
  .fade-up-2 { animation: fadeSlideUp 0.8s ease 0.4s both; }
  .fade-up-3 { animation: fadeSlideUp 0.8s ease 0.7s both; }
  .fade-up-4 { animation: fadeSlideUp 0.8s ease 0.9s both; }

  @keyframes drift1 { 0%,100% { transform:translate(0,0) scale(1); } 50% { transform:translate(4%,3%) scale(1.08); } }
  @keyframes drift2 { 0%,100% { transform:translate(0,0) scale(1.05); } 50% { transform:translate(-5%,-2%) scale(1); } }
  .drift-1 { animation: drift1 14s ease-in-out infinite; }
  .drift-2 { animation: drift2 18s ease-in-out infinite; }

  @keyframes marquee { from { transform:translateX(0); } to { transform:translateX(-50%); } }
  .marquee-track { animation: marquee 24s linear infinite; width:max-content; }

  .nav-shell { transition: background-color 0.4s ease, box-shadow 0.4s ease; }
  .nav-shell.scrolled { background-color: rgba(246,241,230,0.9); backdrop-filter: blur(12px); box-shadow: 0 1px 0 rgba(23,20,15,0.08); }
  .nav-shell.scrolled .nav-logo, .nav-shell.scrolled .nav-link { color: var(--ink) !important; }
  .nav-shell.scrolled .nav-cta { background-color: var(--ink) !important; color:#fff !important; }
  .nav-shell.scrolled #menuIcon, .nav-shell.scrolled #menuBtn { color: var(--ink); }

  .mobile-menu-panel { transition: height 0.5s cubic-bezier(0.16,1,0.3,1), opacity 0.5s cubic-bezier(0.16,1,0.3,1); height:0; opacity:0; pointer-events:none; }
  .mobile-menu-panel.open { height:100vh; opacity:1; pointer-events:auto; }
  .mobile-menu-inner { transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1) 0.1s, transform 0.6s cubic-bezier(0.16,1,0.3,1) 0.1s; opacity:0; transform:translateY(32px); }
  .mobile-menu-panel.open .mobile-menu-inner { opacity:1; transform:translateY(0); }

  #menuIconOpen, #menuIconClose { transition: all 0.3s ease; }
  #menuIconClose { opacity:0; transform:rotate(-90deg) scale(0.5); }
  #menuBtn.open #menuIconOpen { opacity:0; transform:rotate(90deg) scale(0.5); }
  #menuBtn.open #menuIconClose { opacity:1; transform:rotate(0deg) scale(1); color:var(--ink); }

  .tape-chip { transition: transform 0.25s ease; }
  .tape-chip:hover { transform: rotate(0deg) !important; }

  .project-card { transition: transform 0.3s ease, box-shadow 0.3s ease; }
  .project-card:hover { transform: rotate(0deg) translateY(-6px); box-shadow: 0 20px 40px rgba(23,20,15,0.15); }
</style>
</head>
<body class="w-full">

  <!-- NAVBAR -->
  <nav id="navbar" class="nav-shell fixed top-0 left-0 right-0 z-30 flex items-center justify-between px-6 py-5 md:px-12 lg:px-16">
    <div class="flex items-center gap-10">
      <button onclick="goTo('#home')" class="nav-logo font-display text-lg sm:text-xl font-semibold tracking-tight text-white">simran.</button>
      <div class="hidden md:flex items-center gap-8">
        <button onclick="goTo('#home')" class="nav-link text-sm text-white/80 hover:opacity-100 transition-colors">Home</button>
        <button onclick="goTo('#about')" class="nav-link text-sm text-white/80 hover:opacity-100 transition-colors">About</button>
        <button onclick="goTo('#work')" class="nav-link text-sm text-white/80 hover:opacity-100 transition-colors">Work</button>
        <button onclick="goTo('#skills')" class="nav-link text-sm text-white/80 hover:opacity-100 transition-colors">Skills</button>
        <button onclick="goTo('#contact')" class="nav-link text-sm text-white/80 hover:opacity-100 transition-colors">Contact</button>
      </div>
    </div>

    <div class="hidden md:block">
      <button onclick="goTo('#contact')" class="nav-cta rounded-lg bg-white px-5 py-2 text-sm font-medium text-black hover:scale-105 transition-transform">Let's Talk</button>
    </div>

    <button id="menuBtn" onclick="toggleMenu()" class="md:hidden relative h-10 w-10 z-50 active:scale-90 transition-transform" aria-label="Toggle menu">
      <svg id="menuIconOpen" class="absolute inset-0 m-auto text-white" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="18" x2="20" y2="18"></line></svg>
      <svg id="menuIconClose" class="absolute inset-0 m-auto" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </nav>

  <!-- MOBILE MENU -->
  <div id="mobileMenu" class="mobile-menu-panel fixed inset-x-0 top-0 z-20 overflow-hidden bg-[#17140F]/[.98] backdrop-blur-xl">
    <div class="mobile-menu-inner flex h-full flex-col justify-center px-8">
      <button onclick="goTo('#home')" class="text-left text-3xl font-medium py-2 text-white/90 hover:text-white">Home</button>
      <button onclick="goTo('#about')" class="text-left text-3xl font-medium py-2 text-white/90 hover:text-white">About</button>
      <button onclick="goTo('#work')" class="text-left text-3xl font-medium py-2 text-white/90 hover:text-white">Work</button>
      <button onclick="goTo('#skills')" class="text-left text-3xl font-medium py-2 text-white/90 hover:text-white">Skills</button>
      <button onclick="goTo('#contact')" class="text-left text-3xl font-medium py-2 text-white/90 hover:text-white">Contact</button>
      <button onclick="goTo('#contact')" class="mt-6 w-fit rounded-full bg-white px-8 py-3.5 text-base font-medium text-black hover:scale-105 transition-transform">Let's Talk</button>
    </div>
  </div>

  <!-- HERO -->
  <section id="home" class="relative h-screen w-full overflow-hidden bg-[#17140F]">
    <div class="absolute inset-0">
      <div class="drift-1 absolute -top-1/4 -left-1/4 w-3/4 h-3/4 rounded-full blur-3xl opacity-40" style="background: radial-gradient(circle, var(--rose) 0%, transparent 70%);"></div>
      <div class="drift-2 absolute -bottom-1/4 -right-1/4 w-3/4 h-3/4 rounded-full blur-3xl opacity-30" style="background: radial-gradient(circle, var(--tape) 0%, transparent 70%);"></div>
    </div>

    <div class="relative z-10 flex h-[calc(100vh-80px)] flex-col justify-between px-6 pb-10 pt-12 sm:pb-12 sm:pt-16 md:px-12 md:pb-16 md:pt-20 lg:px-16">
      <div class="max-w-3xl">
        <div class="fade-up-1 mb-4 sm:mb-6 inline-flex items-center gap-2 text-xs sm:text-sm text-white/90">
          <i data-lucide="sparkles" class="w-3.5 h-3.5"></i>
          Graphic Design · Digital Media
        </div>
        <h1 class="fade-up-2 font-display text-3xl sm:text-5xl md:text-6xl lg:text-7xl font-medium leading-[1.1] tracking-tight text-white">
