    <div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:gap-6">
      <a href="mailto:simranrose2004@gmail.com" class="inline-flex items-center gap-2 text-sm sm:text-base rounded-lg bg-white px-5 py-3 font-medium hover:scale-105 transition-transform w-fit text-[var(--ink)]">
        <i data-lucide="mail" class="w-4 h-4"></i> simranrose2004@gmail.com
      </a>
      <a href="tel:+19297926505" class="inline-flex items-center gap-2 text-sm sm:text-base rounded-lg px-5 py-3 font-medium hover:scale-105 transition-transform w-fit text-white border border-white/25">
        <i data-lucide="phone" class="w-4 h-4"></i> 929 792 6505
      </a>
      <a href="https://www.linkedin.com/in/simransampla/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm sm:text-base rounded-lg px-5 py-3 font-medium hover:scale-105 transition-transform w-fit text-white border border-white/25">
