          <span class="tape-chip text-xs sm:text-sm px-3 py-1.5 rounded-sm border border-[var(--paper-line)] bg-[var(--paper)] text-[var(--ink)]" style="transform:rotate(1deg);">Adobe Illustrator</span>
          <span class="tape-chip text-xs sm:text-sm px-3 py-1.5 rounded-sm border border-[var(--paper-line)] bg-[var(--paper)] text-[var(--ink)]" style="transform:rotate(-1deg);">Adobe InDesign</span>
          <span class="tape-chip text-xs sm:text-sm px-3 py-1.5 rounded-sm border border-[var(--paper-line)] bg-[var(--paper)] text-[var(--ink)]" style="transform:rotate(1deg);">Canva</span>
          <span class="tape-chip text-xs sm:text-sm px-3 py-1.5 rounded-sm border border-[var(--paper-line)] bg-[var(--paper)] text-[var(--ink)]" style="transform:rotate(-1deg);">Layout &amp; Typography</span>
          <span class="tape-chip text-xs sm:text-sm px-3 py-1.5 rounded-sm border border-[var(--paper-line)] bg-[var(--paper)] text-[var(--ink)]" style="transform:rotate(1deg);">Flyer &amp; Poster Design</span>
        </div>
      </div>

      <div>
        <div class="flex items-center gap-2 mb-4 text-[var(--ink)]">
          <i data-lucide="megaphone" class="w-4.5 h-4.5"></i>
          <h3 class="font-medium text-sm sm:text-base">Strategy &amp; Marketing</h3>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="tape-chip text-xs sm:text-sm px-3 py-1.5 rounded-sm border border-[var(--paper-line)] bg-[var(--paper)] text-[var(--ink)]" style="transform:rotate(-2deg);">Adobe Digital Marketing</span>
          <span class="tape-chip text-xs sm:text-sm px-3 py-1.5 rounded-sm border border-[var(--paper-line)] bg-[var(--paper)] text-[var(--ink)]" style="transform:rotate(2deg);">Social Media Content &amp; Strategy</span>
          <span class="tape-chip text-xs sm:text-sm px-3 py-1.5 rounded-sm border border-[var(--paper-line)] bg-[var(--paper)] text-[var(--ink)]" style="transform:rotate(-2deg);">Digital Marketing Strategy</span>
          <span class="tape-chip text-xs sm:text-sm px-3 py-1.5 rounded-sm border border-[var(--paper-line)] bg-[var(--paper)] text-[var(--ink)]" style="transform:rotate(2deg);">Meta Social Media Marketing</span>
          <span class="tape-chip text-xs sm:text-sm px-3 py-1.5 rounded-sm border border-[var(--paper-line)] bg-[var(--paper)] text-[var(--ink)]" style="transform:rotate(-2deg);">Campaign Planning</span>
        </div>
      </div>

      <div>
        <div class="flex items-center gap-2 mb-4 text-[var(--ink)]">
          <i data-lucide="pen-tool" class="w-4.5 h-4.5"></i>
          <h3 class="font-medium text-sm sm:text-base">Communication</h3>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="tape-chip text-xs sm:text-sm px-3 py-1.5 rounded-sm border border-[var(--paper-line)] bg-[var(--paper)] text-[var(--ink)]" style="transform:rotate(-3deg);">Brand Storytelling</span>
          <span class="tape-chip text-xs sm:text-sm px-3 py-1.5 rounded-sm border border-[var(--paper-line)] bg-[var(--paper)] text-[var(--ink)]" style="transform:rotate(3deg);">Visual Communication</span>
          <span class="tape-chip text-xs sm:text-sm px-3 py-1.5 rounded-sm border border-[var(--paper-line)] bg-[var(--paper)] text-[var(--ink)]" style="transform:rotate(-3deg);">Content Creation</span>
          <span class="tape-chip text-xs sm:text-sm px-3 py-1.5 rounded-sm border border-[var(--paper-line)] bg-[var(--paper)] text-[var(--ink)]" style="transform:rotate(3deg);">Multimedia Production</span>
        </div>
      </div>
    </div>
  </section>

  <!-- WORK -->
  <section id="work" class="px-6 py-20 md:px-12 md:py-28 lg:px-16 bg-[var(--paper)]">
    <p class="text-xs tracking-widest uppercase mb-4 text-[var(--rose)]">Work</p>
    <h2 class="font-display text-2xl sm:text-3xl md:text-4xl font-medium mb-12 text-[var(--ink)]">A few things I've made.</h2>

    <div class="grid gap-8 sm:grid-cols-2">
      <div class="project-card p-6 sm:p-8 bg-white border border-[var(--paper-line)] shadow-[0_8px_24px_rgba(23,20,15,0.08)]" style="transform:rotate(-2deg);">
        <div class="flex items-center gap-2 text-xs mb-3 text-[var(--rose)]"><i data-lucide="layers" class="w-3.5 h-3.5"></i>Ad Campaign · India</div>
        <h3 class="font-display text-lg sm:text-xl font-medium mb-3 text-[var(--ink)]">Admissions Open — School Campaign</h3>
        <p class="text-sm leading-relaxed text-[var(--muted)]">A full ad campaign for a school's admissions season — posters, social creatives, and messaging built to catch parents' attention and drive enrollment.</p>
      </div>

      <div class="project-card p-6 sm:p-8 bg-white border border-[var(--paper-line)] shadow-[0_8px_24px_rgba(23,20,15,0.08)]" style="transform:rotate(1.5deg);">
        <div class="flex items-center gap-2 text-xs mb-3 text-[var(--rose)]"><i data-lucide="layers" class="w-3.5 h-3.5"></i>Coursework · Brand Campaign</div>
        <h3 class="font-display text-lg sm:text-xl font-medium mb-3 text-[var(--ink)]">Campaign in Class</h3>
        <p class="text-sm leading-relaxed text-[var(--muted)]">A concept-to-execution campaign built for a class brief — positioning, key visual, and a small rollout across print and social formats.</p>
      </div>

      <div class="project-card p-6 sm:p-8 bg-white border border-[var(--paper-line)] shadow-[0_8px_24px_rgba(23,20,15,0.08)]" style="transform:rotate(-1deg);">
        <div class="flex items-center gap-2 text-xs mb-3 text-[var(--rose)]"><i data-lucide="layers" class="w-3.5 h-3.5"></i>Print Design</div>
        <h3 class="font-display text-lg sm:text-xl font-medium mb-3 text-[var(--ink)]">Flyer Series</h3>
        <p class="text-sm leading-relaxed text-[var(--muted)]">A set of event and promo flyers exploring hierarchy, color, and type pairing for fast, at-a-glance reading.</p>
      </div>

      <div class="project-card p-6 sm:p-8 bg-white border border-[var(--paper-line)] shadow-[0_8px_24px_rgba(23,20,15,0.08)]" style="transform:rotate(2deg);">
        <div class="flex items-center gap-2 text-xs mb-3 text-[var(--rose)]"><i data-lucide="layers" class="w-3.5 h-3.5"></i>Social &amp; Digital Ads</div>
        <h3 class="font-display text-lg sm:text-xl font-medium mb-3 text-[var(--ink)]">Ad Collection</h3>
        <p class="text-sm leading-relaxed text-[var(--muted)]">A rotating collection of ad creatives designed for feed and story formats, tuned for scroll-stopping first impressions.</p>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="px-6 py-20 md:px-12 md:py-28 lg:px-16 bg-[#17140F]">
    <p class="text-xs tracking-widest uppercase mb-4 text-[var(--tape)]">Contact</p>
